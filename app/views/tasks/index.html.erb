<ul>
  <% @tasks.each do |task| %>
    <li>
      <%= task.completed ? 'DONE' : 'TODO'  %> - <%= link_to task.title, task_path(task) %> -
      <%= link_to "Delete",
            task_path(task),
            method: :delete,
            data: { confirm: "Are you sure?" } %>
    </li>
  <% end %>
</ul>

<hr>
<%= link_to "Add a new task", tasks_new_path %>



